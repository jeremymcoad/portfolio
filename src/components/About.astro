---
import { site } from '@data/site';

type AboutParagraph =
  | string
  | {
      text?: string;
      link?: { text: string; href: string };
      textAfter?: string;
      heading?: string;
      bullets?: string[];
      techItems?: any[];
    };

type HobbiesParagraph = AboutParagraph;

const aboutParagraphs = site.about.paragraphs as readonly AboutParagraph[];
const hobbiesParagraphs = site.hobbies.paragraphs as readonly HobbiesParagraph[];

/* ✅ LINKS MAP */
const techLinks: Record<string, string> = {
  cv: '/Jeremy-Coad-Healthcare-Technology-Product-Owner.pdf',
  'linked in': 'https://www.linkedin.com/in/jeremymcoad/',
  email: 'mailto:jeremymatthewcoad@gmail.com'
};

const isMail = (tech: string) => tech === 'email';
---

<!-- HOBBIES SECTION -->
<section
  id="hobbies"
  class="mb-24 scroll-mt-24 lg:mb-32 lg:scroll-mt-8"
  style="background-color: #0F172A; padding: 25px; margin-top: 0 !important; border-radius: 0.375rem;"
  aria-labelledby="hobbies-heading"
>
  <h2 id="hobbies-heading" class="section-heading">About Me</h2>

  <div class="space-y-8 body-copy">
    {hobbiesParagraphs.map((p) =>
      typeof p === 'string' ? (
        <p>{p}</p>
      ) : (
        <>
          {'text' in p && p.text !== undefined && (
            <p>
              {p.text}
              {p.link && (
                <a
                  href={p.link.href}
                  class="subtle-link text-accent"
                  target="_blank"
                  rel="noreferrer"
                >
                  {p.link.text}
                </a>
              )}
              {p.textAfter}
            </p>
          )}

          {p.heading && (
            <div class="space-y-2">
              <p class="font-semibold">{p.heading}</p>

              {p.bullets && (
                <ul class="list-disc space-y-1 pl-5">
                  {p.bullets.map((bullet) => (
                    <li>{bullet}</li>
                  ))}
                </ul>
              )}

              {p.techItems && (
                <div class="mt-3 flex flex-wrap gap-2">
                  {p.techItems.map((tech) => (
                    <a
                      href={techLinks[tech.label ?? tech]}
                      target={isMail(tech.label ?? tech) ? undefined : '_blank'}
                      rel={isMail(tech.label ?? tech) ? undefined : 'noreferrer noopener'}
                      class="rounded-full border border-accent/30 bg-accent/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-accent transition hover:bg-accent/20"
                    >
                      {tech.label ?? tech}
                    </a>
                  ))}
                </div>
              )}
            </div>
          )}
        </>
      )
    )}
  </div>

  <div class="reveal-content grid items-start gap-10">
    <div class="overflow-hidden rounded-xl border border-slate-700 shadow-lg" style="margin-top: 35px;">
      <video
        src="https://github.com/jeremymcoad/portfolio/releases/download/v1.0.0/yesterday.mp4"
        controls
        autoplay
        muted
        loop
        playsinline
        class="w-full max-w-3xl aspect-[16/7] object-cover rounded-xl shadow-lg"
      ></video>
    </div>

    <div class="flex gap-4 overflow-x-auto scroll-smooth snap-x snap-mandatory pb-4">
      <img src="1.jpg" class="h-36 w-56 flex-shrink-0 object-cover rounded-xl snap-start transition hover:scale-105" />
      <img src="2.jpg" class="h-36 w-56 flex-shrink-0 object-cover rounded-xl snap-start transition hover:scale-105" />
      <img src="3.jpg" class="h-36 w-56 flex-shrink-0 object-cover rounded-xl snap-start transition hover:scale-105" />
      <img src="4.jpg" class="h-36 w-56 flex-shrink-0 object-cover rounded-xl snap-start transition hover:scale-105" />
      <img src="5.jpg" class="h-36 w-56 flex-shrink-0 object-cover rounded-xl snap-start transition hover:scale-105" />
      <img src="6.jpg" class="h-36 w-56 flex-shrink-0 object-top rounded-xl snap-start transition hover:scale-105" />
    </div>
  </div>
</section>

<!-- ABOUT SECTION -->
<section
  id="about"
  class="mb-24 scroll-mt-24 lg:mb-32 lg:scroll-mt-8"
  style="background-color: #0F172A; padding: 25px; margin-top: 0 !important; border-radius: 0.375rem;"
  aria-labelledby="about-heading"
>
  <h2 id="about-heading" class="section-heading">Professional</h2>

  <div class="reveal-content grid items-start gap-10">
    <div class="space-y-8 body-copy">
      {aboutParagraphs.map((p) =>
        typeof p === 'string' ? (
          <p>{p}</p>
        ) : (
          <>
            {'text' in p && p.text !== undefined && (
              <p>
                {p.text}
                {p.link && (
                  <a
                    href={p.link.href}
                    class="subtle-link text-accent"
                    target="_blank"
                    rel="noreferrer"
                  >
                    {p.link.text}
                  </a>
                )}
                {p.textAfter}
              </p>
            )}

            {p.heading && (
              <div class="space-y-2">
                <p class="font-semibold">{p.heading}</p>

                {p.bullets && (
                  <ul class="list-disc space-y-1 pl-5">
                    {p.bullets.map((bullet) => (
                      <li>{bullet}</li>
                    ))}
                  </ul>
                )}

                {p.techItems && (
                  <div class="mt-3 flex flex-wrap gap-2">
                    {p.techItems.map((tech) => (
                      <a
                        href={techLinks[tech.label ?? tech]}
                        target={isMail(tech.label ?? tech) ? undefined : '_blank'}
                        rel={isMail(tech.label ?? tech) ? undefined : 'noreferrer noopener'}
                        class="rounded-full border border-accent/30 bg-accent/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-accent transition hover:bg-accent/20"
                      >
                        {tech.label ?? tech}
                      </a>
                    ))}
                  </div>
                )}
              </div>
            )}
          </>
        )
      )}
    </div>
  </div>
</section>

<style is:global>
  .reveal-content {
    opacity: 0;
    transform: translateY(20px);
    animation: revealIn 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
  }

  @keyframes revealIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>